# ══════════════════════════════════════════════════════════════════════════════
# CoreMarket — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=coremarket
POSTGRES_PASSWORD=change-me-to-strong-password
POSTGRES_DB=coremarket

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-to-a-long-random-secret-key

# ── Object Storage (MinIO) ────────────────────────────────────────────────────
MINIO_ACCESS_KEY=change-me-minio-access-key
MINIO_SECRET_KEY=change-me-minio-secret-key
MINIO_BUCKET=coremarket

# Production: URL where MinIO is reachable from the browser (for presigned URLs)
# Dev: http://localhost:9000
# Prod: https://storage.yourdomain.com  OR  http://<server-ip>:9000
MINIO_PUBLIC_URL=http://localhost:9000

# ── Public URL (production only) ──────────────────────────────────────────────
# Your server's public domain or IP. Used for CORS, sitemap, OG tags.
# Dev: http://localhost
# Prod: https://yourdomain.com
PUBLIC_URL=http://localhost
NEXT_PUBLIC_SITE_URL=http://localhost

# ── Search (Elasticsearch) ────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX_PREFIX=coremarket
# Set to false to disable ES and fall back to SQL ILIKE search
SEARCH_ENABLED=true

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# json | text
LOG_FORMAT=json

# ── Grafana ───────────────────────────────────────────────────────────────────
# Change this in production!
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password
# Production: accessed via nginx on the server's IP at /grafana/, not the domain.
# Set to http://<server-ip>/grafana/
GRAFANA_ROOT_URL=http://localhost/grafana/

# ── Telegram Notifications (optional) ────────────────────────────────────────
# 1. Create a bot: message @BotFather on Telegram → /newbot → copy the token
# 2. Get chat ID: message @userinfobot → copy the id field
#    OR visit: https://api.telegram.org/bot<TOKEN>/getUpdates → result[0].message.chat.id
# 3. Edit grafana/provisioning/alerting/contact_points.yml → set chatid as quoted string
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERTS_ENABLED=false

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_WORKER_CONCURRENCY=2
