# ══════════════════════════════════════════════════════════════════════════════
# CoreMarket Backend — Environment Variables
# Used when running the backend OUTSIDE Docker (local development without Compose).
# When using Docker Compose, set these in the root .env — they are injected automatically.
# ══════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=coremarket
POSTGRES_PASSWORD=change-me
POSTGRES_NAME=coremarket
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

ASYNC_DATABASE_URL=postgresql+asyncpg://coremarket:change-me@localhost:5432/coremarket

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-to-a-long-random-secret-key
JWT_ACCESS_TOKEN_EXPIRES=1800
JWT_REFRESH_TOKEN_EXPIRES=604800
JWT_ALGORITHM=HS256

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── Object Storage (MinIO) ────────────────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=change-me-minio-access-key
MINIO_SECRET_KEY=change-me-minio-secret-key
MINIO_BUCKET=coremarket
MINIO_PUBLIC_URL=http://localhost:9000

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_WORKER_CONCURRENCY=2

# ── Search (Elasticsearch) ────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=coremarket
SEARCH_ENABLED=true

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── OpenTelemetry (Tempo tracing) ─────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=coremarket-backend

# ── Prometheus ────────────────────────────────────────────────────────────────
PROMETHEUS_ENABLED=true

# ── Telegram Notifications (optional) ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERTS_ENABLED=false
