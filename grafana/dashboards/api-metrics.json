{
  "uid": "api-metrics",
  "title": "CoreMarket — API Metrics",
  "description": "HTTP request rate, latency (p50/p95/p99), error rate, active connections, top slow endpoints",
  "tags": ["coremarket", "api", "prometheus"],
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1, "type": "stat",
      "title": "Requests / sec",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum(rate(coremarket_http_requests_total[5m]))",
        "legendFormat": "req/s"
      }],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "red", "value": 200 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "colorMode": "background" }
    },
    {
      "id": 2, "type": "stat",
      "title": "p95 Latency",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(coremarket_http_request_duration_seconds_bucket[5m])) by (le))",
        "legendFormat": "p95"
      }],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.5 },
            { "color": "red", "value": 2 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 3, "type": "stat",
      "title": "Error Rate (5xx)",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum(rate(coremarket_http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(coremarket_http_requests_total[5m])) * 100",
        "legendFormat": "error %"
      }],
      "fieldConfig": {
        "defaults": { "unit": "percent", "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 4, "type": "stat",
      "title": "Active Requests",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum(coremarket_http_requests_in_progress)",
        "legendFormat": "active"
      }],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 20 },
            { "color": "red", "value": 100 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 5, "type": "stat",
      "title": "4xx Client Errors / sec",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum(rate(coremarket_http_requests_total{status_code=~\"4..\"}[5m]))",
        "legendFormat": "4xx/s"
      }],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 5 },
            { "color": "red", "value": 20 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 6, "type": "stat",
      "title": "Homepage Cache Hit Rate",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum(rate(coremarket_homepage_requests_total{source=\"cache_hit\"}[5m])) / sum(rate(coremarket_homepage_requests_total[5m])) * 100",
        "legendFormat": "cache hit %"
      }],
      "fieldConfig": {
        "defaults": { "unit": "percent", "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 70 },
            { "color": "green", "value": 95 }
          ]}
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 10, "type": "timeseries",
      "title": "Request Rate by Status Code",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(coremarket_http_requests_total{status_code=~\"2..\"}[5m]))", "legendFormat": "2xx" },
        { "expr": "sum(rate(coremarket_http_requests_total{status_code=~\"3..\"}[5m]))", "legendFormat": "3xx" },
        { "expr": "sum(rate(coremarket_http_requests_total{status_code=~\"4..\"}[5m]))", "legendFormat": "4xx" },
        { "expr": "sum(rate(coremarket_http_requests_total{status_code=~\"5..\"}[5m]))", "legendFormat": "5xx" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "2xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "4xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "5xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 11, "type": "timeseries",
      "title": "Latency Percentiles (p50 / p95 / p99)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(coremarket_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(coremarket_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(coremarket_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 12, "type": "timeseries",
      "title": "p95 Latency by Endpoint (top 10)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "topk(10, histogram_quantile(0.95, sum(rate(coremarket_http_request_duration_seconds_bucket[5m])) by (le, endpoint)))",
        "legendFormat": "{{endpoint}}"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] } }
    },
    {
      "id": 13, "type": "table",
      "title": "Slowest Endpoints — p95 Latency",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "topk(15, histogram_quantile(0.95, sum(rate(coremarket_http_request_duration_seconds_bucket[5m])) by (le, endpoint, method)))",
        "legendFormat": "{{method}} {{endpoint}}",
        "instant": true,
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "displayName", "value": "p95 Latency" }, { "id": "custom.displayMode", "value": "color-background" }] }
        ]
      },
      "options": { "sortBy": [{ "desc": true, "displayName": "p95 Latency" }] }
    },
    {
      "id": 14, "type": "table",
      "title": "Request Count by Endpoint",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "topk(15, sum by (method, endpoint) (rate(coremarket_http_requests_total[5m])))",
        "legendFormat": "{{method}} {{endpoint}}",
        "instant": true,
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "displayName", "value": "req/s" }] }
        ]
      },
      "options": { "sortBy": [{ "desc": true, "displayName": "req/s" }] }
    }
  ]
}
