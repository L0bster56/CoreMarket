{
  "uid": "postgres-metrics",
  "title": "CoreMarket — PostgreSQL",
  "description": "Active connections, transactions/sec, cache hit rate, dead tuples, DB size",
  "tags": ["coremarket", "postgres", "prometheus"],
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1, "type": "stat",
      "title": "Active Connections",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum(pg_stat_activity_count{state=\"active\"})",
        "legendFormat": "active"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 50 },
          { "color": "red", "value": 100 }
        ]}
      }},
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 2, "type": "stat",
      "title": "Cache Hit Rate",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum(rate(pg_stat_database_blks_hit[5m])) / (sum(rate(pg_stat_database_blks_hit[5m])) + sum(rate(pg_stat_database_blks_read[5m]))) * 100",
        "legendFormat": "cache hit %"
      }],
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [
          { "color": "red", "value": null },
          { "color": "yellow", "value": 90 },
          { "color": "green", "value": 99 }
        ]}
      }},
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 3, "type": "stat",
      "title": "Transactions / sec",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum(rate(pg_stat_database_xact_commit[5m])) + sum(rate(pg_stat_database_xact_rollback[5m]))",
        "legendFormat": "txn/s"
      }],
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 4, "type": "stat",
      "title": "Database Size",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum(pg_database_size_bytes)",
        "legendFormat": "db size"
      }],
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 10, "type": "timeseries",
      "title": "Connections by State",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "pg_stat_activity_count",
        "legendFormat": "{{state}}"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 11, "type": "timeseries",
      "title": "Commit vs Rollback Rate",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(pg_stat_database_xact_commit[5m]))", "legendFormat": "commits/s" },
        { "expr": "sum(rate(pg_stat_database_xact_rollback[5m]))", "legendFormat": "rollbacks/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "rollbacks/s" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 12, "type": "timeseries",
      "title": "Buffer Cache — Hits vs Reads",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(pg_stat_database_blks_hit[5m]))", "legendFormat": "cache hits/s" },
        { "expr": "sum(rate(pg_stat_database_blks_read[5m]))", "legendFormat": "disk reads/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "iops" } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 13, "type": "timeseries",
      "title": "Dead Tuples by Table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "topk(10, pg_stat_user_tables_n_dead_tup)",
        "legendFormat": "{{relname}}"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] } }
    },
    {
      "id": 14, "type": "timeseries",
      "title": "Locks",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "pg_locks_count",
        "legendFormat": "{{mode}}"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 15, "type": "timeseries",
      "title": "Temp Files Written",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(pg_stat_database_temp_files[5m]))", "legendFormat": "temp files/s" },
        { "expr": "sum(rate(pg_stat_database_temp_bytes[5m]))", "legendFormat": "temp bytes/s" }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "temp bytes/s" }, "properties": [{ "id": "unit", "value": "Bps" }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    }
  ]
}
