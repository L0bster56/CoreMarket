{
  "uid": "celery-metrics",
  "title": "CoreMarket — Celery Tasks",
  "description": "Task throughput, duration, error rate, and queue backlog per queue",
  "tags": ["coremarket", "celery", "prometheus"],
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1, "type": "stat",
      "title": "Tasks / sec (all queues)",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum(rate(coremarket_celery_tasks_total{status=\"success\"}[5m]))",
        "legendFormat": "tasks/s"
      }],
      "fieldConfig": { "defaults": { "unit": "ops", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [{ "color": "green", "value": null }] }
      }},
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 2, "type": "stat",
      "title": "Failed Tasks / sec",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum(rate(coremarket_celery_tasks_total{status=\"failure\"}[5m]))",
        "legendFormat": "failures/s"
      }],
      "fieldConfig": { "defaults": { "unit": "ops", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 0.1 },
          { "color": "red", "value": 1 }
        ]}
      }},
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 3, "type": "stat",
      "title": "Retries / sec",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum(rate(coremarket_celery_tasks_total{status=\"retry\"}[5m]))",
        "legendFormat": "retries/s"
      }],
      "fieldConfig": { "defaults": { "unit": "ops", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 0.05 },
          { "color": "red", "value": 0.5 }
        ]}
      }},
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 4, "type": "stat",
      "title": "Active Tasks",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum(coremarket_celery_tasks_active)",
        "legendFormat": "active"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 5, "type": "stat",
      "title": "Homepage Snapshot Age",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "coremarket_homepage_snapshot_age_seconds",
        "legendFormat": "age"
      }],
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 300 },
          { "color": "red", "value": 600 }
        ]}
      }},
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 6, "type": "stat",
      "title": "Failure Rate %",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum(rate(coremarket_celery_tasks_total{status=\"failure\"}[5m])) / sum(rate(coremarket_celery_tasks_total[5m])) * 100",
        "legendFormat": "failure %"
      }],
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 2 },
          { "color": "red", "value": 10 }
        ]}
      }},
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 10, "type": "timeseries",
      "title": "Task Throughput by Queue",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum by (queue) (rate(coremarket_celery_tasks_total{status=\"success\"}[5m]))",
        "legendFormat": "{{queue}}"
      }],
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 11, "type": "timeseries",
      "title": "Task Duration p95 by Task",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (le, task_name) (rate(coremarket_celery_task_duration_seconds_bucket[5m])))",
        "legendFormat": "{{task_name}}"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] } }
    },
    {
      "id": 12, "type": "timeseries",
      "title": "Failures & Retries by Queue",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (queue) (rate(coremarket_celery_tasks_total{status=\"failure\"}[5m]))", "legendFormat": "failure {{queue}}" },
        { "expr": "sum by (queue) (rate(coremarket_celery_tasks_total{status=\"retry\"}[5m]))", "legendFormat": "retry {{queue}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 13, "type": "timeseries",
      "title": "Active Tasks by Queue",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum by (queue) (coremarket_celery_tasks_active)",
        "legendFormat": "{{queue}}"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 14, "type": "table",
      "title": "Task Performance Summary",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (task_name, queue) (rate(coremarket_celery_tasks_total{status=\"success\"}[5m]))",
          "legendFormat": "{{task_name}}",
          "instant": true,
          "format": "table",
          "refId": "success_rate"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, task_name) (rate(coremarket_celery_task_duration_seconds_bucket[5m])))",
          "legendFormat": "{{task_name}}",
          "instant": true,
          "format": "table",
          "refId": "p95_duration"
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "renameByName": { "Value #success_rate": "Tasks/s", "Value #p95_duration": "p95 Duration" } } }
      ],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "p95 Duration" }, "properties": [{ "id": "unit", "value": "s" }] },
          { "matcher": { "id": "byName", "options": "Tasks/s" }, "properties": [{ "id": "unit", "value": "ops" }] }
        ]
      }
    }
  ]
}
