{
  "uid": "redis-metrics",
  "title": "CoreMarket — Redis",
  "description": "Cache hit/miss ratio, memory usage, operations per second, connected clients",
  "tags": ["coremarket", "redis", "prometheus"],
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1, "type": "stat",
      "title": "Cache Hit Rate",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "rate(redis_keyspace_hits_total[5m]) / (rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m])) * 100",
        "legendFormat": "hit rate %"
      }],
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [
          { "color": "red", "value": null },
          { "color": "yellow", "value": 70 },
          { "color": "green", "value": 90 }
        ]}
      }},
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 2, "type": "stat",
      "title": "Memory Used",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "redis_memory_used_bytes",
        "legendFormat": "used"
      }],
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 3, "type": "stat",
      "title": "Operations / sec",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "rate(redis_commands_total[5m])",
        "legendFormat": "ops/s"
      }],
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 4, "type": "stat",
      "title": "Connected Clients",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "redis_connected_clients",
        "legendFormat": "clients"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 50 },
          { "color": "red", "value": 200 }
        ]}
      }},
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 10, "type": "timeseries",
      "title": "Cache Hit / Miss Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(redis_keyspace_hits_total[5m])", "legendFormat": "hits/s" },
        { "expr": "rate(redis_keyspace_misses_total[5m])", "legendFormat": "misses/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "hits/s" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "misses/s" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 11, "type": "timeseries",
      "title": "Memory — Used vs Peak",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "redis_memory_used_bytes", "legendFormat": "used" },
        { "expr": "redis_memory_used_peak_bytes", "legendFormat": "peak" },
        { "expr": "redis_memory_max_bytes", "legendFormat": "max (maxmemory)" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 12, "type": "timeseries",
      "title": "Command Rate by Type",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "topk(10, rate(redis_commands_total[5m]))",
        "legendFormat": "{{cmd}}"
      }],
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] } }
    },
    {
      "id": 13, "type": "timeseries",
      "title": "Blocked Clients & Rejected Connections",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "redis_blocked_clients", "legendFormat": "blocked" },
        { "expr": "rate(redis_rejected_connections_total[5m])", "legendFormat": "rejected/s" }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "blocked" }, "properties": [{ "id": "unit", "value": "short" }] },
          { "matcher": { "id": "byName", "options": "rejected/s" }, "properties": [{ "id": "unit", "value": "connps" }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    }
  ]
}
