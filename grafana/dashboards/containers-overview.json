{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "CoreMarket containers — log volume, activity per service, filtering by container",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": true,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": ["coremarket"],
      "targetBlank": false,
      "title": "CoreMarket",
      "type": "dashboards"
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Log Volume Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "lines/s",
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" }
          },
          "mappings": [],
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["mean", "max", "sum"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum by (compose_service) (count_over_time({job=\"docker\", compose_service=~\"$service\"} [$__interval]))",
          "legendFormat": "{{compose_service}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Log Volume by Service",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 },
      "id": 3,
      "title": "Container Stats",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 11 },
      "id": 4,
      "options": {
        "displayMode": "gradient",
        "minVizHeight": 10,
        "minVizWidth": 0,
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true,
        "valueMode": "color"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sort_desc(sum by (compose_service) (count_over_time({job=\"docker\", compose_service=~\"$service\"} [$__range])))",
          "legendFormat": "{{compose_service}}",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Total Log Lines by Service (in range)",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 11 },
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({compose_service=\"backend\"} | json | level=\"INFO\" [$__interval]))",
          "legendFormat": "INFO",
          "queryType": "range",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({compose_service=\"backend\"} | json | level=\"WARNING\" [$__interval]))",
          "legendFormat": "WARNING",
          "queryType": "range",
          "refId": "B"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({compose_service=\"backend\"} | json | level=\"ERROR\" [$__interval]))",
          "legendFormat": "ERROR",
          "queryType": "range",
          "refId": "C"
        }
      ],
      "title": "Backend Log Levels",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "id": 6,
      "title": "Backend Structured Logs",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "id": 7,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "{compose_service=\"backend\"} | json | level=~\"$level\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Backend Logs (filtered by level)",
      "type": "logs"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "id": 8,
      "title": "All Container Logs",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 31 },
      "id": 9,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "{job=\"docker\", compose_service=~\"$service\"}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "All Container Logs (use service filter above)",
      "type": "logs"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["coremarket", "containers"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "loki",
        "refresh": 1,
        "regex": "",
        "type": "datasource",
        "label": "Data Source"
      },
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "loki", "uid": "${datasource}" },
        "definition": "",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "service",
        "options": [],
        "query": {
          "label": "compose_service",
          "refId": "StandardVariableQuery",
          "stream": "{job=\"docker\"}",
          "type": 1
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query",
        "label": "Service"
      },
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "loki", "uid": "${datasource}" },
        "definition": "",
        "hide": 0,
        "includeAll": true,
        "multi": false,
        "name": "level",
        "options": [
          { "selected": true, "text": "All", "value": "$__all" },
          { "selected": false, "text": "INFO", "value": "INFO" },
          { "selected": false, "text": "WARNING", "value": "WARNING" },
          { "selected": false, "text": "ERROR", "value": "ERROR" }
        ],
        "query": "INFO,WARNING,ERROR",
        "refresh": 0,
        "regex": "",
        "sort": 0,
        "type": "custom",
        "label": "Log Level"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "CoreMarket — Containers Overview",
  "uid": "coremarket-containers",
  "version": 1,
  "weekStart": ""
}
